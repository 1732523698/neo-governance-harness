{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "neo:iteration_manifest_entry",
  "title": "NEO 4.0 P4-AUTONOMY C1C3-S3a append-only iteration-manifest entry (one JSONL line per round)",
  "_home": "<RunRoot>/iteration_manifest.jsonl - append-only canonical-JSON lines; one entry PER ROUND (spec sec-5 197-198); STOPPED rounds land their row BEFORE the stop surfaces (NB-2 write-ahead); any read/write/parse failure => LEDGER_FAILURE semantics",
  "_status": "PROPOSED 4.0-P4-C1C3-S3a (schema-add halt). schema_id + run_id are ENGINE-STAMPED by Add-NeoIterationManifestEntry from the persisted run manifest - a caller can never bind a row to a foreign run. NOT_EVALUATED sentinels mark stages a STOPPED round never reached. Every field required; no optional escape hatches in breaker state.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "run_id", "slice_id", "round", "attempt_seq", "baseline_head_sha",
               "baseline_tree_hash", "changed_count", "changed_paths_hash", "classification",
               "findings_summary", "auditor_slot_status", "auditor_slot_recommendation",
               "auditor_identity", "external_lane_status", "effective_seam_tier", "cap_events",
               "stop_reason_code", "notify_gate_class", "notify_sent", "notify_deduped",
               "notify_refused", "notify_reason", "timestamp_utc"],
  "properties": {
    "schema_id":         { "type": "string", "const": "neo:iteration_manifest_entry" },
    "run_id":            { "type": "string", "minLength": 1 },
    "slice_id":          { "type": "string", "minLength": 1 },
    "round":             { "type": "integer", "minimum": 0 },
    "attempt_seq":       { "type": "integer", "minimum": 1 },
    "baseline_head_sha": { "type": "string", "minLength": 1 },
    "baseline_tree_hash":{ "type": "string", "minLength": 1 },
    "changed_count":     { "type": "integer", "minimum": 0 },
    "changed_paths_hash":{ "type": "string", "minLength": 1 },
    "classification":    { "type": "string", "enum": ["STOPPED", "STOPPED_THREE_BRANCH", "THREE_BRANCH_CLEAN"] },
    "findings_summary":  { "type": "string", "minLength": 1 },
    "auditor_slot_status": { "type": "string", "enum": ["SATISFIED", "BLOCKED", "NOT_EVALUATED"] },
    "auditor_slot_recommendation": { "type": "string", "enum": ["GO", "NO-GO", "NEEDS-MORE", "NOT_EVALUATED"] },
    "auditor_identity":  { "type": "string", "minLength": 1 },
    "external_lane_status": { "type": "string", "enum": ["NOT_WIRED", "MISSING", "STALE", "UNPARSEABLE", "NO_GO", "GO", "NOT_EVALUATED"] },
    "effective_seam_tier": { "type": "string", "enum": ["lightweight", "isolated", "full_isolated", "NOT_EVALUATED"] },
    "cap_events":        { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "stop_reason_code":  { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
    "notify_gate_class": { "type": "string", "enum": ["NONE", "BREAKER_TRIP", "ESCALATION_STOP", "DECISION_NEEDED", "SESSION_END"] },
    "notify_sent":       { "type": "boolean" },
    "notify_deduped":    { "type": "boolean" },
    "notify_refused":    { "type": "boolean" },
    "notify_reason":     { "type": "string" },
    "timestamp_utc":     { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" }
  }
}
