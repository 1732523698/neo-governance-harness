{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "neo:constraint_package",
  "title": "NEO 4.0 CONSTRAINT_PACKAGE",
  "_home": "./program/CONSTRAINT_PACKAGE.json (JSON authoritative per Q1)",
  "_status": "INSTALLED 4.0-P3-A (from the KEPT 4.0 Session-0 draft). Live spine schema. JUDGING-class artifact (artifact_classes: constraint). Per D6/A4 it is FAIL-CLOSED against cheap-producer edits: editable only through a separately-gated constraint-edit session. Separate from impl with its own gate + validator (D9 / v4 5.7).",
  "type": "object",
  "additionalProperties": false,
  "required": ["package_id", "package_version", "constraints", "test_harness_ref", "profile_risk_ref", "_provenance"],
  "properties": {
    "package_id": { "type": "string", "minLength": 1 },
    "package_version": { "type": "string" },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "statement", "kind", "severity"],
        "properties": {
          "id": { "type": "string" },
          "statement": { "type": "string" },
          "kind": { "type": "string", "enum": ["functional", "security", "data", "performance", "compatibility", "regulatory", "operational"] },
          "severity": { "type": "string", "enum": ["blocking", "high", "medium", "low"] },
          "traces_to_spec": { "type": "array", "items": { "type": "string" }, "description": "acceptance_criteria ids this constraint enforces." }
        }
      }
    },
    "test_harness_ref": { "type": "object", "additionalProperties": false, "required": ["artifact_id", "content_hash"], "properties": { "artifact_id": { "type": "string" }, "content_hash": { "type": "string" } }, "description": "Bound harness (test_harness class), validated INDEPENDENTLY before its results count (D9)." },
    "profile_risk_ref": { "type": "object", "additionalProperties": false, "required": ["artifact_id", "content_hash"], "properties": { "artifact_id": { "type": "string" }, "content_hash": { "type": "string" } }, "description": "Bound risk profile (profile_risk class). Reconciles with NEO_APP_PROFILE spine schema." },
    "capability_tier": { "type": "string", "description": "Capability-DOMINANT tier of this app slice (D9): capability, not raw size, drives tier." },
    "_provenance": { "$ref": "neo:common_provenance_envelope" }
  }
}
