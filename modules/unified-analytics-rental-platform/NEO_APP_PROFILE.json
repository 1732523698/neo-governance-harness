{
  "binding": {
    "profile_schema_id": "neo:app_profile",
    "profile_schema_version": "3.0.0",
    "profile_semver": "2.6.0",
    "neo_governance_version": "v3.0",
    "generated_view_is_authoritative": false,
    "supersedes_markdown_profile": "modules/unified-analytics-rental-platform/NEO_APP_PROFILE.md"
  },
  "identity": {
    "app_slug": "unified-analytics-rental-platform",
    "app_name": "Unified Analytics Rental Platform"
  },
  "governance_semantics": {
    "records_constraints_not_permission": true,
    "real_mode_requires_separate_signoff": true,
    "secret_values_forbidden": true
  },
  "boundary_approval": {
    "boundary_approved": true,
    "not_approved_for": [
      "general future real-app execution",
      "production apply/deploy without separate explicit approval"
    ],
    "fixture_proof_never_becomes_real_permission": true,
    "scoped_approvals": []
  },
  "denylist": {
    "entries": [
      {
        "pattern": "backend/src/logic/payments.ts",
        "is_glob": false
      },
      {
        "pattern": "backend/src/logic/pool.ts",
        "is_glob": false
      },
      {
        "pattern": "backend/src/logic/charges.ts",
        "is_glob": false
      },
      {
        "pattern": "backend/src/logic/future-charges.ts",
        "is_glob": false
      },
      {
        "pattern": "backend/src/logic/status.ts",
        "is_glob": false
      },
      {
        "pattern": "backend/src/logic/tenants-ledger-combined.ts",
        "is_glob": false
      },
      {
        "pattern": "backend/src/routes/tenants-ledger-combined.ts",
        "is_glob": false
      },
      {
        "pattern": "backend/src/logic/future-charges-review.ts",
        "is_glob": false
      },
      {
        "pattern": "backend/src/logic/futureChargesAutoScheduler.ts",
        "is_glob": false
      },
      {
        "pattern": "backend/src/logic/reports.ts",
        "is_glob": false
      },
      {
        "pattern": "backend/src/routes/reports.ts",
        "is_glob": false
      },
      {
        "pattern": "backend/src/logic/utility-v2-reports.ts",
        "is_glob": false
      },
      {
        "pattern": "backend/src/routes/utility-v2-reports.ts",
        "is_glob": false
      },
      {
        "pattern": "backend/src/logic/settlement.ts",
        "is_glob": false
      },
      {
        "pattern": "backend/src/logic/paymentsAllocationSuggest.ts",
        "is_glob": false
      },
      {
        "pattern": "backend/src/routes/payments.ts",
        "is_glob": false
      },
      {
        "pattern": "backend/src/routes/charges.ts",
        "is_glob": false
      },
      {
        "pattern": "backend/src/logic/dashboard.ts",
        "is_glob": false
      },
      {
        "pattern": "backend/src/logic/dashboard-utility-v2.ts",
        "is_glob": false
      },
      {
        "pattern": "backend/src/routes/dashboard.ts",
        "is_glob": false
      },
      {
        "pattern": "backend/src/routes/dashboard-utility-v2.ts",
        "is_glob": false
      },
      {
        "pattern": "frontend/src/app/dashboard/**",
        "is_glob": true
      },
      {
        "pattern": "frontend/src/components/dashboard/**",
        "is_glob": true
      },
      {
        "pattern": "frontend/src/hooks/useDashboard.ts",
        "is_glob": false
      },
      {
        "pattern": "frontend/src/hooks/useDashboardTierB.ts",
        "is_glob": false
      },
      {
        "pattern": "frontend/src/lib/guidance/dashboardAlerts.ts",
        "is_glob": false
      },
      {
        "pattern": "frontend/src/i18n/dictionaries/en/dashboard.ts",
        "is_glob": false
      },
      {
        "pattern": "frontend/src/i18n/dictionaries/fr/dashboard.ts",
        "is_glob": false
      },
      {
        "pattern": "frontend/src/i18n/dictionaries/zh-CN/dashboard.ts",
        "is_glob": false
      }
    ]
